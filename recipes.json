      "instructions": [
        {
          "text": "Mix the flour, low-fat quark, baking powder, salt, olive oil, wheat bran, and water until a smooth dough forms.",
          "ingredient_links": [
            "ing_1782837419502_f1a9q",
            "ing_1782837419503_k7m2x",
            "ing_1782837419504_r4d8p",
            "ing_1782837419505_j6n1v",
            "ing_1782837419506_h3w5c",
            "ing_1782837419507_t9y2l",
            "ing_1782837419508_b8q4n"
          ]
        },
        {
          "text": "Divide the dough into about 6 equal portions.",
          "ingredient_links": []
        },
        {
          "text": "Flatten each portion to about 0.5 cm thick.",
          "ingredient_links": []
        },
        {
          "text": "Cook the flatbreads in a hot frying pan until golden brown on both sides.",
          "ingredient_links": []
